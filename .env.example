# .env.example
# Host ports are offset from the distributed-rag-system stack so both can run at
# once. Only Ollama (11434) is shared.

DEBUG=true

# PostgreSQL (task + step log, approvals, audit, api keys)
DATABASE_URL=postgresql://agents:agents_dev_password@localhost:5633/agents

# Redis (live SSE stream relay + KV cache)
REDIS_URL=redis://localhost:6390

# Qdrant (long-term agent memory)
QDRANT_HOST=localhost
QDRANT_PORT=6353
QDRANT_MEMORY_COLLECTION=agent_memory

# Redpanda / Kafka (durable task queue)
KAFKA_BROKERS=localhost:9093

# Ollama (shared with the RAG stack)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:14b
EMBEDDING_MODEL=nomic-embed-text

# Auth (JWT)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
API_KEYS=dev-key-1,dev-key-2

# Observability
OTLP_ENDPOINT=http://localhost:4318
TRACING_ENABLED=false

# Service ports
API_PORT=8010
WORKER_HEALTH_PORT=8011